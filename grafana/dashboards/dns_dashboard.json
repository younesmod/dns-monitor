{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "DNS Server Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "DNS Server Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "title": "Shecan (5.200.200.200)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "dns_server_up{dns_name=\"shecan\"}",
          "legendFormat": "Shecan"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "403 DNS-1 (217.218.127.127)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "dns_server_up{dns_name=\"403_1\"}",
          "legendFormat": "403-1"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "title": "403 DNS-2 (217.218.155.155)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "dns_server_up{dns_name=\"403_2\"}",
          "legendFormat": "403-2"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "type": "row",
      "title": "Response Time (seconds)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },

    {
      "id": 6,
      "title": "DNS Response Times",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "dns_response_time_seconds",
          "legendFormat": "{{ dns_name }} → {{ domain }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 2     }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },

    {
      "id": 7,
      "type": "row",
      "title": "DNS Resolution Results per Domain",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },

    {
      "id": 8,
      "title": "Resolved IPs — All DNS × All Domains",
      "type": "table",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "dns_resolved_ip_info == 1",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "dns_name":    "DNS Server",
              "dns_ip":      "IP",
              "domain":      "Domain",
              "resolved_ip": "Resolved IP"
            },
            "indexByName": {
              "domain":      0,
              "dns_name":    1,
              "dns_ip":      2,
              "resolved_ip": 3
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Resolved IP" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Domain", "desc": false }]
      }
    },

    {
      "id": 9,
      "type": "row",
      "title": "Mismatch Detection",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false
    },

    {
      "id": 10,
      "title": "DNS Mismatch Status per Domain",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "dns_response_mismatch",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "domain": "Domain",
              "Value":  "Mismatch"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
            "custom": {
		"align": "auto",
        	"cellOptions": {
        		"type": "auto"
        	},
        	"inspect": false,
        	"filterable": true
      		}
    	},
    "overrides": [
      {
        "matcher": { "id": "byName", "options": "Mismatch" },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value":{
	    	"type":"color-background" ,
		"mode":"basic"
	    }
          },
          {
            "id": "mappings",
            "value": [
              {
                "type": "value",
                "options": {
                  "0": { "text": "✅ OK",       "color": "transparent", "index": 0 },
                  "1": { "text": "🔴 MISMATCH", "color": "red",   "index": 1 }
                }
              }
            ]
          },
          {
            "thresholds" :{
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "red",   "value": 80   }
              ]
            }
          }
        ]
      }
    ]
        },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      }
    },

    {
      "id": 11,
      "title": "Query Success Rate per DNS",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "avg by (dns_name) (dns_query_success) * 100",
          "legendFormat": "{{ dns_name }}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "green",  "value": 90   }
            ]
          }
        }
      }
    },
    

    {
      "id": 12,
      "title": "TEST: Raw dns_server_up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
          {
              "expr": "dns_server_up",
              "refId": "A",
              "legendFormat": "{{ dns_name }}",
              "instant": true
          }
      ],
      "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "background",
          "graphMode": "none"
      },
      "fieldConfig": {
          "defaults": {
              "thresholds": {
                  "mode": "absolute",
                  "steps": [
                      { "color": "red",   "value": null },
                      { "color": "green", "value": 1    }
                  ]
              }
          }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["dns", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DNS Monitoring",
  "uid": "dns-monitoring-v1",
  "version": 1
}
